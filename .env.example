# =================================================================
# DDUK ERP Integrated Environment Variables Sample
# =================================================================
# Instructions:
# 1. Copy this file to `.env` in the root directory.
# 2. Fill in the actual values for your local environment.

# -----------------------------------------------------------------
# [COMMON]
# -----------------------------------------------------------------
APP_ENV=development
DEFAULT_TIMEZONE=Asia/Seoul

# -----------------------------------------------------------------
# [BACKEND - Spring Boot]
# -----------------------------------------------------------------
DB_URL=jdbc:mysql://gateway01.ap-northeast-1.prod.aws.tidbcloud.com:4000/dduk_erp?useSSL=true&serverTimezone=Asia/Seoul
DB_USERNAME=replace_with_tidb_user
DB_PASSWORD=replace_with_tidb_password
JPA_DDL_AUTO=update
JWT_SECRET=replace_with_a_long_random_secret_at_least_64_chars
JWT_EXPIRATION=86400000

# Optional database tuning
DB_DIALECT=mysql
DB_POOL_SIZE=10

# -----------------------------------------------------------------
# [AI SERVER - Flask]
# -----------------------------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=true
AI_SERVER_HOST=127.0.0.1
AI_SERVER_PORT=5000
OPENAI_API_KEY=replace_with_api_key
OPENAI_MODEL=gpt-4o-mini
OCR_PROVIDER=tesseract
BACKEND_API_BASE_URL=http://localhost:8080/api/v1

# -----------------------------------------------------------------
# [RPA - Playwright]
# -----------------------------------------------------------------
RPA_BROWSER=chromium
RPA_HEADLESS=true
RPA_BASE_URL=http://localhost:5500
RPA_LOGIN_ID=admin
RPA_LOGIN_PASSWORD=admin123
DOWNLOAD_DIR=./outputs
PLAYWRIGHT_TIMEOUT_MS=30000
